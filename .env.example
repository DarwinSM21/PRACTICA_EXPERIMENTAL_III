# ==============================================================
# SGED - Variables de entorno (Bloque B.1)
# Copie este archivo a .env antes de ejecutar make up:
#   cp .env.example .env
# Valores por defecto seguros SOLO para desarrollo local.
# ==============================================================

# --- Base de datos PostgreSQL ---
DB_USER=postgres
DB_PASSWORD=changeme
DB_URL=jdbc:postgresql://postgres:5432/sged_db

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- JWT (RFC 7519) ---
# Minimo 32 caracteres. CAMBIAR en cualquier entorno no local.
JWT_SECRET=SGED_SUPER_SECRET_KEY_2026_SEGURA_MINIMO_32_CARACTERES
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=604800000
JWT_ISSUER=sged-backend
JWT_AUDIENCE=sged-frontend

# --- Cookies (Bloque A.1) ---
# true exige HTTPS. En desarrollo local sin TLS usar false.
COOKIE_SECURE=false

# --- Rate limiting login (OWASP A07) ---
LOGIN_MAX_INTENTOS=5
LOGIN_VENTANA_MINUTOS=15

# --- Cache Redis del listado (TTL externo, Bloque A.1) ---
CACHE_TTL_SECONDS=60

# --- Flyway: en Docker el esquema viene de db/schema.sql (initdb) ---
FLYWAY_ENABLED=false
